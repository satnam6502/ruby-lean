/-
The Batcher network preserves permutation.
-/
theorem batcher_network_perm (l : List (BitVec 8)) : (batcher_network l).Perm l := by
  unfold batcher_network
  apply List.Perm.trans (layer6_perm _)
  apply List.Perm.trans (layer5_perm _)
  apply List.Perm.trans (layer4_perm _)
  apply List.Perm.trans (layer3_perm _)
  apply List.Perm.trans (layer2_perm _)
  apply layer1_perm

/-
Layer 1 establishes the initial bitonic shapes.
-/
def PostLayer1 (l : List (BitVec 8)) : Prop :=
  l.length = 8 ∧
  l[0]! ≤ l[1]! ∧
  l[2]! ≥ l[3]! ∧
  l[4]! ≤ l[5]! ∧
  l[6]! ≥ l[7]!

lemma layer1_establishes_PostLayer1 (l : List (BitVec 8)) (h : l.length = 8) :
  PostLayer1 (layer1 l) := by
    rcases l with ( _ | ⟨ a, _ | ⟨ b, _ | ⟨ c, _ | ⟨ d, _ | ⟨ e, _ | ⟨ f, _ | ⟨ g, _ | ⟨ h, _ | l ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ) <;> simp_all +decide;
    constructor;
    · simp +decide [ layer1 ];
    · unfold layer1;
      unfold CAS; simp +decide [ * ] ;
      grind

/-
Layer 2 establishes the second stage bitonic properties.
-/
def PostLayer2 (l : List (BitVec 8)) : Prop :=
  l.length = 8 ∧
  l[0]! ≤ l[2]! ∧
  l[1]! ≤ l[3]! ∧
  l[0]! ≤ l[3]! ∧
  l[1]! ≤ l[2]! ∧
  l[4]! ≥ l[6]! ∧
  l[5]! ≥ l[7]! ∧
  l[4]! ≥ l[7]! ∧
  l[5]! ≥ l[6]!

lemma layer2_establishes_PostLayer2 (l : List (BitVec 8)) (h : PostLayer1 l) :
  PostLayer2 (layer2 l) := by
    unfold PostLayer1 at h; unfold layer2; simp_all? ( config := { decide := Bool.true } ) ;
    rcases l with ( _ | ⟨ x0, _ | ⟨ x1, _ | ⟨ x2, _ | ⟨ x3, _ | ⟨ x4, _ | ⟨ x5, _ | ⟨ x6, _ | ⟨ x7, _ | l ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ) <;> simp_all +decide;
    unfold PostLayer2; simp +decide [ CAS ] ;
    split_ifs <;> simp_all +decide [ BitVec.le_def ];
    all_goals omega;

/-
Layer 3 establishes that the first half is sorted ascending and the second half is sorted descending.
-/
def PostLayer3 (l : List (BitVec 8)) : Prop :=
  l.length = 8 ∧
  l[0]! ≤ l[1]! ∧ l[1]! ≤ l[2]! ∧ l[2]! ≤ l[3]! ∧
  l[4]! ≥ l[5]! ∧ l[5]! ≥ l[6]! ∧ l[6]! ≥ l[7]!

lemma layer3_establishes_PostLayer3 (l : List (BitVec 8)) (h : PostLayer2 l) :
  PostLayer3 (layer3 l) := by
    rcases l with ( _ | ⟨ a, _ | ⟨ b, _ | ⟨ c, _ | ⟨ d, _ | ⟨ e, _ | ⟨ f, _ | ⟨ g, _ | ⟨ h, _ | l ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ) <;> simp_all? +arith +decide [ PostLayer2, PostLayer3 ];
    unfold layer3; simp +decide [ CAS ] ;
    grind

/-
Definition of `sort4` and `IsBitonic4`. `sort4` corresponds to layers 5 and 6 for a 4-element chunk. `IsBitonic4` characterizes bitonic sequences of length 4.
-/
def sort4 (l : List (BitVec 8)) : List (BitVec 8) :=
  match l with
  | x0 :: x1 :: x2 :: x3 :: [] =>
    let (y0, y2) := CAS true x0 x2
    let (y1, y3) := CAS true x1 x3
    let (z0, z1) := CAS true y0 y1
    let (z2, z3) := CAS true y2 y3
    [z0, z1, z2, z3]
  | _ => l

def IsBitonic4 (l : List (BitVec 8)) : Prop :=
  l.length = 4 ∧
  let x0 := l[0]!
  let x1 := l[1]!
  let x2 := l[2]!
  let x3 := l[3]!
  ¬(x0 < x1 ∧ x1 > x2 ∧ x2 < x3 ∧ x3 > x0) ∧
  ¬(x0 > x1 ∧ x1 < x2 ∧ x2 > x3 ∧ x3 < x0)

/-
Definitions of Up-Then-Down and Down-Then-Up sequences of length 4.
-/
def IsUpThenDown4 (l : List (BitVec 8)) : Prop :=
  l.length = 4 ∧
  ∃ (k : Fin 5),
    (∀ i j, i < j → j < k → l[i]! ≤ l[j]!) ∧
    (∀ i j, k ≤ i → i < j → j < 4 → l[i]! ≥ l[j]!)

def IsDownThenUp4 (l : List (BitVec 8)) : Prop :=
  l.length = 4 ∧
  ∃ (k : Fin 5),
    (∀ i j, i < j → j < k → l[i]! ≥ l[j]!) ∧
    (∀ i j, k ≤ i → i < j → j < 4 → l[i]! ≤ l[j]!)

/-
`sort4` sorts any bitonic sequence of length 4. Proof uses `omega` on `toNat` values.
-/
lemma sort4_sorts_bitonic (l : List (BitVec 8)) (h_len : l.length = 4) (h_bitonic : IsBitonic4 l) :
  List.Sorted (· ≤ ·) (sort4 l) := by
    unfold sort4;
    rcases l with ( _ | ⟨ x0, _ | ⟨ x1, _ | ⟨ x2, _ | ⟨ x3, _ | l ⟩ ⟩ ⟩ ⟩ ) <;> simp_all +decide;
    unfold CAS; split_ifs <;> simp_all +decide ;
    all_goals unfold IsBitonic4 at h_bitonic; simp_all +decide [ not_lt_of_ge, le_of_lt ] ;
    all_goals simp_all +decide [ BitVec.le_def, BitVec.lt_def ];
    all_goals omega

/-
`sort4` sorts Up-Then-Down sequences.
-/
lemma sort4_sorts_UpThenDown (l : List (BitVec 8)) (h : IsUpThenDown4 l) :
  List.Sorted (· ≤ ·) (sort4 l) := by
    rcases h with ⟨ h_len, k, hk ⟩;
    -- We need to show that `sort4 l` is sorted for any `l` that is up-then-down.
    apply sort4_sorts_bitonic;
    · assumption;
    · fin_cases k <;> simp +decide [ Fin.forall_fin_succ ] at hk ⊢;
      · constructor <;> aesop;
      · unfold IsBitonic4; aesop;
      · constructor <;> aesop;
      · constructor <;> aesop;
      · exact ⟨ h_len, by aesop ⟩

/-
`sort4` sorts Down-Then-Up sequences.
-/
lemma sort4_sorts_DownThenUp (l : List (BitVec 8)) (h : IsDownThenUp4 l) :
  List.Sorted (· ≤ ·) (sort4 l) := by
    obtain ⟨ k, hk ⟩ := h;
    rcases l with ( _ | ⟨ a, _ | ⟨ b, _ | ⟨ c, _ | ⟨ d, _ | l ⟩ ⟩ ⟩ ⟩ ) <;> simp_all +decide;
    revert hk;
    simp +decide [ Fin.forall_fin_succ, Fin.exists_fin_succ ];
    unfold sort4; simp +decide [ List.Sorted ] ;
    unfold CAS; simp +decide [ *, le_total ] ;
    grind

/-
`layer6 (layer5 l)` is equivalent to applying `sort4` to the two halves of `l`.
-/
lemma layer56_eq_sort4_halves (l : List (BitVec 8)) (h : l.length = 8) :
  layer6 (layer5 l) = sort4 (l.take 4) ++ sort4 (l.drop 4) := by
  rcases l with ( _ | ⟨ x0, _ | ⟨ x1, _ | ⟨ x2, _ | ⟨ x3, _ | ⟨ x4, _ | ⟨ x5, _ | ⟨ x6, _ | ⟨ x7, _ | l ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ) <;> simp_all
  unfold layer6 layer5 sort4
  simp

/-
`layer4` partitions the sequence into a lower half and an upper half such that every element in the lower half is less than or equal to every element in the upper half.
-/
lemma layer4_partition (l : List (BitVec 8)) (h : PostLayer3 l) :
  let l' := layer4 l
  ∀ x ∈ l'.take 4, ∀ y ∈ l'.drop 4, x ≤ y := by
    rcases l with ( _ | ⟨ x0, _ | ⟨ x1, _ | ⟨ x2, _ | ⟨ x3, _ | ⟨ x4, _ | ⟨ x5, _ | ⟨ x6, _ | ⟨ x7, _ | l ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ) <;> simp_all +decide;
    all_goals unfold PostLayer3 at h; simp_all +decide;
    unfold layer4; simp +decide [ CAS ] ;
    split_ifs <;> simp_all +decide [ BitVec.le_def ];
    all_goals omega;

/-
`IsUpThenDown4` implies `IsBitonic4`.
-/
lemma IsUpThenDown4_implies_IsBitonic4 (l : List (BitVec 8)) (h : IsUpThenDown4 l) : IsBitonic4 l := by
  rcases h with ⟨h_len, k, h_asc, h_desc⟩
  unfold IsBitonic4
  simp [h_len]
  fin_cases k
  all_goals {
    simp only [Fin.forall_fin_succ, Fin.forall_fin_zero_pi] at h_asc h_desc
    simp_all
    -- In each case, we have some inequalities.
    -- We need to show negation of M and W.
    -- M: x0 < x1 > x2 < x3 > x0
    -- W: x0 > x1 < x2 > x3 < x0
    -- Use `bv_decide` or `omega` if possible, or just logic.
    -- Since we have `BitVec`, `omega` works on `toNat`.
    try simp only [← BitVec.toNat_le, ← BitVec.toNat_lt] at *
    try omega
  }

/-
`IsDownThenUp4` implies `IsBitonic4`.
-/
lemma IsDownThenUp4_implies_IsBitonic4 (l : List (BitVec 8)) (h : IsDownThenUp4 l) : IsBitonic4 l := by
  rcases h with ⟨h_len, k, h_desc, h_asc⟩
  unfold IsBitonic4
  simp [h_len]
  fin_cases k
  all_goals {
    simp only [Fin.forall_fin_succ, Fin.forall_fin_zero_pi] at h_asc h_desc
    simp_all
    try simp only [← BitVec.toNat_le, ← BitVec.toNat_lt] at *
    try omega
  }

/-
If the input to `layer4` consists of an ascending half and a descending half, then the two halves of the output of `layer4` are bitonic.
-/
lemma layer4_halves_bitonic (l : List (BitVec 8)) (h : PostLayer3 l) :
  IsBitonic4 ((layer4 l).take 4) ∧ IsBitonic4 ((layer4 l).drop 4) := by
    unfold IsBitonic4 PostLayer3 at *;
    rcases l with ( _ | ⟨ a, _ | ⟨ b, _ | ⟨ c, _ | ⟨ d, _ | ⟨ e, _ | ⟨ f, _ | ⟨ g, _ | ⟨ h, _ | l ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ) <;> simp_all +decide [ layer4 ];
    unfold CAS; simp +decide [ h ] ;
    grind

/-
`sort4` returns a permutation of its input.
-/
lemma sort4_perm (l : List (BitVec 8)) : (sort4 l).Perm l := by
  unfold sort4;
  rcases l with ( _ | ⟨ x0, _ | ⟨ x1, _ | ⟨ x2, _ | ⟨ x3, _ | l ⟩ ⟩ ⟩ ⟩ ) <;> simp +decide [ CAS ];
  grind

/-
Helper lemma: Concatenation of two sorted lists where the first is less than or equal to the second is sorted.
-/
lemma List.Sorted.append_of_le {α} [Preorder α] {l1 l2 : List α}
  (h1 : List.Sorted (· ≤ ·) l1) (h2 : List.Sorted (· ≤ ·) l2)
  (hle : ∀ x ∈ l1, ∀ y ∈ l2, x ≤ y) :
  List.Sorted (· ≤ ·) (l1 ++ l2) := by
    induction l1 <;> aesop

/-
Layers 4, 5, and 6 sort a sequence that satisfies PostLayer3. Proof uses the decomposition into `sort4` on halves and the partition property of `layer4`.
-/
lemma layer456_sorts (l : List (BitVec 8)) (h : PostLayer3 l) :
  List.Sorted (· ≤ ·) (layer6 (layer5 (layer4 l))) := by
    -- By lemma `layer4_partition`, the first half of `layer4 l` is less than or equal to the second half.
    have h_partition : ∀ x ∈ (layer4 l).take 4, ∀ y ∈ (layer4 l).drop 4, x ≤ y := by
      apply layer4_partition; assumption;
    -- By lemma `layer56_eq_sort4_halves`, `layer6 (layer5 l)` is equivalent to applying `sort4` to the two halves of `l`.
    have h_sort4 : layer6 (layer5 (layer4 l)) = sort4 ((layer4 l).take 4) ++ sort4 ((layer4 l).drop 4) := by
      convert layer56_eq_sort4_halves ( layer4 l ) _;
      rcases l with ( _ | ⟨ a, _ | ⟨ b, _ | ⟨ c, _ | ⟨ d, _ | ⟨ e, _ | ⟨ f, _ | ⟨ g, _ | ⟨ h, _ | l ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ) <;> simp_all +decide [ layer4 ];
      all_goals cases h; simp_all +decide [ PostLayer3 ] ;
    -- By lemma `sort4_sorts_bitonic`, `sort4` sorts bitonic sequences.
    have h_sort4_bitonic : List.Sorted (· ≤ ·) (sort4 ((layer4 l).take 4)) ∧ List.Sorted (· ≤ ·) (sort4 ((layer4 l).drop 4)) := by
      have h_sort4_bitonic : IsBitonic4 ((layer4 l).take 4) ∧ IsBitonic4 ((layer4 l).drop 4) := by
        exact?;
      exact ⟨ sort4_sorts_bitonic _ ( by simp +decide [ h_sort4_bitonic.1.1 ] ) h_sort4_bitonic.1, sort4_sorts_bitonic _ ( by simp +decide [ h_sort4_bitonic.2.1 ] ) h_sort4_bitonic.2 ⟩;
    -- By lemma `List.Sorted.append_of_le`, the concatenation of two sorted lists where the first is less than or equal to the second is sorted.
    have h_concat_sorted : ∀ {l1 l2 : List (BitVec 8)}, List.Sorted (· ≤ ·) l1 → List.Sorted (· ≤ ·) l2 → (∀ x ∈ l1, ∀ y ∈ l2, x ≤ y) → List.Sorted (· ≤ ·) (l1 ++ l2) := by
      intros l1 l2 hl1 hl2 hle; exact (by
      rw [ List.Sorted ] at *;
      rw [ List.pairwise_append ] ; aesop);
    contrapose! h_concat_sorted;
    use sort4 ((layer4 l).take 4), sort4 ((layer4 l).drop 4);
    simp_all +decide [ List.Sorted ];
    intro x hx y hy; have := List.Perm.subset ( sort4_perm ( List.take 4 ( layer4 l ) ) ) hx; have := List.Perm.subset ( sort4_perm ( List.drop 4 ( layer4 l ) ) ) hy; aesop;

/-
Final proof of correctness for the bsort module.
-/
theorem bsort_correct (input : bsort.Input) (state : bsort.State) (output : bsort.Output) (new_state : bsort.State) :
  bsort.relationalModule.relation input state output new_state →
  let in_list := bsort.to_list input.in_data
  let out_list := bsort.to_list output.out_data
  List.Sorted (· ≤ ·) out_list ∧ List.Perm in_list out_list := by
    -- Apply the lemma that states the Batcher network sorts the input.
    intro h_relational
    have h_sorted : List.Sorted (· ≤ ·) (bsort.to_list output.out_data) := by
      rw [ bsort_implements_network input state output new_state h_relational ];
      apply layer456_sorts;
      apply_rules [ layer3_establishes_PostLayer3, layer2_establishes_PostLayer2, layer1_establishes_PostLayer1 ];
    have := bsort_implements_network input state output new_state h_relational;
    exact ⟨ h_sorted, this ▸ batcher_network_perm _ |> List.Perm.symm ⟩

/-
Layers 4, 5, and 6 sort a sequence that satisfies PostLayer3. Proof uses the decomposition into `sort4` on halves and the partition property of `layer4`.
-/
lemma layer456_sorts_final (l : List (BitVec 8)) (h : PostLayer3 l) :
  List.Sorted (· ≤ ·) (layer6 (layer5 (layer4 l))) := by
    exact?

/-
Final proof of correctness for the bsort module (renamed to avoid conflict).
-/
theorem bsort_correctness (input : bsort.Input) (state : bsort.State) (output : bsort.Output) (new_state : bsort.State) :
  bsort.relationalModule.relation input state output new_state →
  let in_list := bsort.to_list input.in_data
  let out_list := bsort.to_list output.out_data
  List.Sorted (· ≤ ·) out_list ∧ List.Perm in_list out_list := by
    -- Apply the lemma `bsort_correct` to conclude the proof.
    apply bsort_correct
