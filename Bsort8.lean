/-
Helper function to unflatten a 64-bit vector into a list of 8 8-bit vectors.
-/
def bsort.to_list (v : BitVec 64) : List (BitVec 8) :=
  [v.extractLsb 63 56, v.extractLsb 55 48, v.extractLsb 47 40, v.extractLsb 39 32,
   v.extractLsb 31 24, v.extractLsb 23 16, v.extractLsb 15 8, v.extractLsb 7 0]

/-
Definition of the Batcher bitonic sorting network for 8 elements.
-/
def CAS (asc : Bool) (a b : BitVec 8) : BitVec 8 × BitVec 8 :=
  if asc then
    if a ≤ b then (a, b) else (b, a)
  else
    if a ≥ b then (a, b) else (b, a)

def layer1 (l : List (BitVec 8)) : List (BitVec 8) :=
  match l with
  | x0 :: x1 :: x2 :: x3 :: x4 :: x5 :: x6 :: x7 :: [] =>
    let (y0, y1) := CAS true x0 x1
    let (y2, y3) := CAS false x2 x3
    let (y4, y5) := CAS true x4 x5
    let (y6, y7) := CAS false x6 x7
    [y0, y1, y2, y3, y4, y5, y6, y7]
  | _ => l

def layer2 (l : List (BitVec 8)) : List (BitVec 8) :=
  match l with
  | x0 :: x1 :: x2 :: x3 :: x4 :: x5 :: x6 :: x7 :: [] =>
    let (y0, y2) := CAS true x0 x2
    let (y1, y3) := CAS true x1 x3
    let (y4, y6) := CAS false x4 x6
    let (y5, y7) := CAS false x5 x7
    [y0, y1, y2, y3, y4, y5, y6, y7]
  | _ => l

def layer3 (l : List (BitVec 8)) : List (BitVec 8) :=
  match l with
  | x0 :: x1 :: x2 :: x3 :: x4 :: x5 :: x6 :: x7 :: [] =>
    let (y0, y1) := CAS true x0 x1
    let (y2, y3) := CAS true x2 x3
    let (y4, y5) := CAS false x4 x5
    let (y6, y7) := CAS false x6 x7
    [y0, y1, y2, y3, y4, y5, y6, y7]
  | _ => l

def layer4 (l : List (BitVec 8)) : List (BitVec 8) :=
  match l with
  | x0 :: x1 :: x2 :: x3 :: x4 :: x5 :: x6 :: x7 :: [] =>
    let (y0, y4) := CAS true x0 x4
    let (y1, y5) := CAS true x1 x5
    let (y2, y6) := CAS true x2 x6
    let (y3, y7) := CAS true x3 x7
    [y0, y1, y2, y3, y4, y5, y6, y7]
  | _ => l

def layer5 (l : List (BitVec 8)) : List (BitVec 8) :=
  match l with
  | x0 :: x1 :: x2 :: x3 :: x4 :: x5 :: x6 :: x7 :: [] =>
    let (y0, y2) := CAS true x0 x2
    let (y1, y3) := CAS true x1 x3
    let (y4, y6) := CAS true x4 x6
    let (y5, y7) := CAS true x5 x7
    [y0, y1, y2, y3, y4, y5, y6, y7]
  | _ => l

def layer6 (l : List (BitVec 8)) : List (BitVec 8) :=
  match l with
  | x0 :: x1 :: x2 :: x3 :: x4 :: x5 :: x6 :: x7 :: [] =>
    let (y0, y1) := CAS true x0 x1
    let (y2, y3) := CAS true x2 x3
    let (y4, y5) := CAS true x4 x5
    let (y6, y7) := CAS true x6 x7
    [y0, y1, y2, y3, y4, y5, y6, y7]
  | _ => l

def batcher_network (l : List (BitVec 8)) : List (BitVec 8) :=
  layer6 (layer5 (layer4 (layer3 (layer2 (layer1 l)))))

/-
Helper lemma: `if BitVec.ofBool c ≠ 0 then t else f` is equivalent to `if c then t else f`.
-/
lemma bitvec_ite_ofBool_ne_zero {w : Nat} (c : Prop) [Decidable c] (t f : BitVec w) :
  (if BitVec.ofBool c ≠ 0#1 then t else f) = if c then t else f := by
    aesop

/-
Helper lemma: Unfold `CAS` definition.
-/
lemma CAS_eq_if (asc : Bool) (a b : BitVec 8) :
  CAS asc a b = if asc then (if a ≤ b then (a, b) else (b, a)) else (if a ≥ b then (a, b) else (b, a)) := by
    unfold CAS; aesop;

/-
Simplification lemmas for CAS logic.
-/
lemma CAS_true_fst_simp (a b : BitVec 8) :
  (if BitVec.ofBool (a <= b) ≠ 0#1 then a else b) = (CAS true a b).1 := by
    native_decide +revert

lemma CAS_true_snd_simp (a b : BitVec 8) :
  (if BitVec.ofBool (a <= b) ≠ 0#1 then b else a) = (CAS true a b).2 := by
    unfold CAS;
    aesop

lemma CAS_false_fst_simp (a b : BitVec 8) :
  (if BitVec.ofBool (a ≥ b) ≠ 0#1 then a else b) = (CAS false a b).1 := by
    unfold CAS; split_ifs <;> simp_all +decide ;

lemma CAS_false_snd_simp (a b : BitVec 8) :
  (if BitVec.ofBool (a ≥ b) ≠ 0#1 then b else a) = (CAS false a b).2 := by
    unfold CAS ; aesop

/-
Correctness lemmas for layers 1, 2, and 3 of the Batcher sorter.
-/
lemma layer1_correct (in_data out_data : BitVec 64)
    (_000_ _001_ _002_ _003_ _011_ _022_ _033_ _044_ : BitVec 1)
    (h0 : _000_ = BitVec.ofBool (in_data.extractLsb 63 56 ≤ in_data.extractLsb 55 48))
    (h1 : out_data.extractLsb 63 56 = if _000_ ≠ 0#1 then in_data.extractLsb 63 56 else in_data.extractLsb 55 48)
    (h2 : _011_ = BitVec.ofBool (in_data.extractLsb 63 56 ≤ in_data.extractLsb 55 48))
    (h3 : out_data.extractLsb 55 48 = if _011_ ≠ 0#1 then in_data.extractLsb 55 48 else in_data.extractLsb 63 56)
    (h4 : _022_ = BitVec.ofBool (in_data.extractLsb 47 40 ≥ in_data.extractLsb 39 32))
    (h5 : out_data.extractLsb 47 40 = if _022_ ≠ 0#1 then in_data.extractLsb 47 40 else in_data.extractLsb 39 32)
    (h6 : _033_ = BitVec.ofBool (in_data.extractLsb 47 40 ≥ in_data.extractLsb 39 32))
    (h7 : out_data.extractLsb 39 32 = if _033_ ≠ 0#1 then in_data.extractLsb 39 32 else in_data.extractLsb 47 40)
    (h8 : _001_ = BitVec.ofBool (in_data.extractLsb 31 24 ≤ in_data.extractLsb 23 16))
    (h9 : out_data.extractLsb 23 16 = if _001_ ≠ 0#1 then in_data.extractLsb 23 16 else in_data.extractLsb 31 24)
    (h10 : _044_ = BitVec.ofBool (in_data.extractLsb 31 24 ≤ in_data.extractLsb 23 16))
    (h11 : out_data.extractLsb 31 24 = if _044_ ≠ 0#1 then in_data.extractLsb 31 24 else in_data.extractLsb 23 16)
    (h12 : _002_ = BitVec.ofBool (in_data.extractLsb 15 8 ≥ in_data.extractLsb 7 0))
    (h13 : out_data.extractLsb 15 8 = if _002_ ≠ 0#1 then in_data.extractLsb 15 8 else in_data.extractLsb 7 0)
    (h14 : _003_ = BitVec.ofBool (in_data.extractLsb 15 8 ≥ in_data.extractLsb 7 0))
    (h15 : out_data.extractLsb 7 0 = if _003_ ≠ 0#1 then in_data.extractLsb 7 0 else in_data.extractLsb 15 8)
    : bsort.to_list out_data = layer1 (bsort.to_list in_data) := by
      unfold bsort.to_list layer1;
      rw [ h1, h3, h5, h7, h11, h9, h13, h15 ];
      rw [ h0, h2, h4, h6, h8, h10, h12, h14 ];
      unfold CAS;
      rw [ bitvec_ite_ofBool_ne_zero, bitvec_ite_ofBool_ne_zero, bitvec_ite_ofBool_ne_zero, bitvec_ite_ofBool_ne_zero ];
      rw [ bitvec_ite_ofBool_ne_zero, bitvec_ite_ofBool_ne_zero, bitvec_ite_ofBool_ne_zero, bitvec_ite_ofBool_ne_zero ];
      grind

