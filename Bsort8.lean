lemma layer6_correct (in_data out_data : BitVec 64)
    (_039_ _040_ _041_ _042_ _043_ _045_ _046_ _047_ : BitVec 1)
    (h0 : _039_ = BitVec.ofBool (in_data.extractLsb 63 56 ≤ in_data.extractLsb 55 48))
    (h1 : out_data.extractLsb 63 56 = if _039_ ≠ 0#1 then in_data.extractLsb 63 56 else in_data.extractLsb 55 48)
    (h2 : _040_ = BitVec.ofBool (in_data.extractLsb 63 56 ≤ in_data.extractLsb 55 48))
    (h3 : out_data.extractLsb 55 48 = if _040_ ≠ 0#1 then in_data.extractLsb 55 48 else in_data.extractLsb 63 56)
    (h4 : _041_ = BitVec.ofBool (in_data.extractLsb 47 40 ≤ in_data.extractLsb 39 32))
    (h5 : out_data.extractLsb 47 40 = if _041_ ≠ 0#1 then in_data.extractLsb 47 40 else in_data.extractLsb 39 32)
    (h6 : _042_ = BitVec.ofBool (in_data.extractLsb 47 40 ≤ in_data.extractLsb 39 32))
    (h7 : out_data.extractLsb 39 32 = if _042_ ≠ 0#1 then in_data.extractLsb 39 32 else in_data.extractLsb 47 40)
    (h8 : _043_ = BitVec.ofBool (in_data.extractLsb 31 24 ≤ in_data.extractLsb 23 16))
    (h9 : out_data.extractLsb 31 24 = if _043_ ≠ 0#1 then in_data.extractLsb 31 24 else in_data.extractLsb 23 16)
    (h10 : _045_ = BitVec.ofBool (in_data.extractLsb 31 24 ≤ in_data.extractLsb 23 16))
    (h11 : out_data.extractLsb 23 16 = if _045_ ≠ 0#1 then in_data.extractLsb 23 16 else in_data.extractLsb 31 24)
    (h12 : _046_ = BitVec.ofBool (in_data.extractLsb 15 8 ≤ in_data.extractLsb 7 0))
    (h13 : out_data.extractLsb 15 8 = if _046_ ≠ 0#1 then in_data.extractLsb 15 8 else in_data.extractLsb 7 0)
    (h14 : _047_ = BitVec.ofBool (in_data.extractLsb 15 8 ≤ in_data.extractLsb 7 0))
    (h15 : out_data.extractLsb 7 0 = if _047_ ≠ 0#1 then in_data.extractLsb 7 0 else in_data.extractLsb 15 8)
    : bsort.to_list out_data = layer6 (bsort.to_list in_data) := by
      -- By combining the hypotheses, we can show that each step of the layer6 function is correctly applied to the corresponding pairs of elements in the list.
      have h_layer6 : ∀ (x0 x1 x2 x3 x4 x5 x6 x7 : BitVec 8), layer6 [x0, x1, x2, x3, x4, x5, x6, x7] = [if x0 ≤ x1 then x0 else x1, if x0 ≤ x1 then x1 else x0, if x2 ≤ x3 then x2 else x3, if x2 ≤ x3 then x3 else x2, if x4 ≤ x5 then x4 else x5, if x4 ≤ x5 then x5 else x4, if x6 ≤ x7 then x6 else x7, if x6 ≤ x7 then x7 else x6] := by
        intros x0 x1 x2 x3 x4 x5 x6 x7
        simp [layer6, CAS_eq_if];
        split_ifs <;> simp +decide;
      unfold bsort.to_list;
      simp +decide [ *, bitvec_ite_ofBool_eq_zero ]

/-
The bsort circuit implements the Batcher network. Proof using layer correctness lemmas.
-/
theorem bsort_implements_network (input : bsort.Input) (state : bsort.State) (output : bsort.Output) (new_state : bsort.State) :
  bsort.relationalModule.relation input state output new_state →
  bsort.to_list output.out_data = batcher_network (bsort.to_list input.in_data) := by
  intro h
  obtain ⟨_000_, _001_, _002_, _003_, _004_, _005_, _006_, _007_, _008_, _009_, _010_, _011_, _012_, _013_, _014_, _015_, _016_, _017_, _018_, _019_, _020_, _021_, _022_, _023_, _024_, _025_, _026_, _027_, _028_, _029_, _030_, _031_, _032_, _033_, _034_, _035_, _036_, _037_, _038_, _039_, _040_, _041_, _042_, _043_, _044_, _045_, _046_, _047_, phase0_sub0, phase1_sub0, phase1_sub1, phase2_sub0, phase2_sub1, phase2_sub2, h_eqs, h_state⟩ := h
  simp only [List.PropAnd_cons, List.PropAnd_nil] at h_eqs

  have h_l1 : bsort.to_list phase0_sub0 = layer1 (bsort.to_list input.in_data) := by
    apply layer1_correct input.in_data phase0_sub0 _000_ _001_ _002_ _003_ _011_ _022_ _033_ _044_
    all_goals (try simp [h_eqs])

  have h_l2 : bsort.to_list phase1_sub1 = layer2 (bsort.to_list phase0_sub0) := by
    apply layer2_correct phase0_sub0 phase1_sub1 _004_ _005_ _006_ _007_ _008_ _009_ _010_ _012_
    all_goals (try simp [h_eqs])

  have h_l3 : bsort.to_list phase1_sub0 = layer3 (bsort.to_list phase1_sub1) := by
    apply layer3_correct phase1_sub1 phase1_sub0 _013_ _014_ _015_ _016_ _017_ _018_ _019_ _020_
    all_goals (try simp [h_eqs])

  have h_l4 : bsort.to_list phase2_sub2 = layer4 (bsort.to_list phase1_sub0) := by
    apply layer4_correct phase1_sub0 phase2_sub2 _021_ _023_ _024_ _025_ _026_ _027_ _028_ _029_
    all_goals (try simp [h_eqs])

  have h_l5 : bsort.to_list phase2_sub1 = layer5 (bsort.to_list phase2_sub2) := by
    apply layer5_correct phase2_sub2 phase2_sub1 _030_ _031_ _032_ _034_ _035_ _036_ _037_ _038_
    all_goals (try simp [h_eqs])

  have h_l6 : bsort.to_list output.out_data = layer6 (bsort.to_list phase2_sub1) := by
    apply layer6_correct phase2_sub1 output.out_data _039_ _040_ _041_ _042_ _043_ _045_ _046_ _047_
    all_goals (try simp [h_eqs])

  rw [h_l6, h_l5, h_l4, h_l3, h_l2, h_l1]
  rfl

/-
CAS returns a permutation of its input.
-/
lemma CAS_perm (asc : Bool) (a b : BitVec 8) :
  [(CAS asc a b).1, (CAS asc a b).2].Perm [a, b] := by
    cases asc <;> simp +decide [ CAS ];
    · split_ifs <;> simp +decide [ *, List.Perm.swap ];
    · split_ifs <;> simp +decide [ *, List.Perm.swap ]

/-
Layer 1 preserves permutation.
-/
lemma layer1_perm (l : List (BitVec 8)) : (layer1 l).Perm l := by
  rcases l with ( _ | ⟨ x0, _ | ⟨ x1, _ | ⟨ x2, _ | ⟨ x3, _ | ⟨ x4, _ | ⟨ x5, _ | ⟨ x6, _ | ⟨ x7, _ | l ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ) <;> simp +decide [ layer1 ];
  have h_perm : ∀ (a b : BitVec 8), List.Perm [(CAS true a b).1, (CAS true a b).2] [a, b] ∧ List.Perm [(CAS false a b).1, (CAS false a b).2] [a, b] := by
    exact fun a b => ⟨ CAS_perm true a b, CAS_perm false a b ⟩;
  exact List.Perm.append ( List.Perm.append ( List.Perm.append ( h_perm _ _ |>.1 ) ( h_perm _ _ |>.2 ) ) ( h_perm _ _ |>.1 ) ) ( h_perm _ _ |>.2 )

/-
Layer 2 preserves permutation.
-/
lemma perm_swap_2_3 {α} (a b c d : α) (l : List α) : (a :: b :: c :: d :: l).Perm (a :: c :: b :: d :: l) := by
  constructor;
  constructor

lemma layer2_perm (l : List (BitVec 8)) : (layer2 l).Perm l := by
  unfold layer2;
  rcases l with ( _ | ⟨ x0, _ | ⟨ x1, _ | ⟨ x2, _ | ⟨ x3, _ | ⟨ x4, _ | ⟨ x5, _ | ⟨ x6, _ | ⟨ x7, _ | l ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ⟩ ) <;> simp +decide [ List.Perm.swap ];
  unfold CAS; simp +decide [ List.Perm.swap ] ;
  split_ifs <;> simp +decide [ *, List.Perm.swap ];
  all_goals rw [ List.perm_iff_count ] ; intros ; simp +decide [ List.count_cons ] ;
  all_goals ring;

