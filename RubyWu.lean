import Mathlib

set_option linter.mathlibStandardSet false

open scoped BigOperators
open scoped Real
open scoped Nat
open scoped Classical
open scoped Pointwise

set_option maxHeartbeats 0
set_option maxRecDepth 4000
set_option synthInstance.maxHeartbeats 20000
set_option synthInstance.maxSize 128

set_option relaxedAutoImplicit false
set_option autoImplicit false

noncomputable section

/-
Definition of the Ruby type as a relation between two types, and the identity relation (renamed to ruby_id to avoid conflict).
-/
def Ruby (α β : Type) := α → β → Prop

def ruby_id {α : Type} : Ruby α α := fun a b => a = b

/-
Definitions of `not` and `and` relations in Ruby HDL. `not` relates distinct booleans. `and` relates a pair of booleans to their conjunction.
-/
def ruby_not : Ruby Bool Bool := fun a b => a ≠ b

def ruby_and : Ruby (Bool × Bool) Bool := fun (a, b) c => c = (a && b)

/-
Definitions of `max` and `min` relations in Ruby HDL for natural numbers. `max` relates a pair to the larger value, `min` to the smaller.
-/
def ruby_max : Ruby (Nat × Nat) Nat := fun (a, b) c => (a ≥ b ∧ c = a) ∨ (b ≥ a ∧ c = b)

def ruby_min : Ruby (Nat × Nat) Nat := fun (a, b) c => (a < b ∧ c = a) ∨ (b ≤ a ∧ c = b)

/-
Definition of `fork` relation in Ruby HDL. It relates a value to a pair of copies of itself.
-/
def ruby_fork {α : Type} : Ruby α (α × α) := fun a (b, c) => a = b ∧ a = c

/-
Definition of `mux` relation in Ruby HDL. It selects between two inputs based on a control bit.
-/
def ruby_mux {α : Type} : Ruby (Bool × (α × α)) α :=
  fun (c, (x, y)) z => (c = true ∧ z = x) ∨ (c = false ∧ z = y)

/-
Definition of series composition in Ruby HDL. x (R ; S) y iff there exists p such that x R p and p S y.
-/
def ruby_seq {α β γ : Type} (R : Ruby α β) (S : Ruby β γ) : Ruby α γ :=
  fun a c => ∃ b, R a b ∧ S b c

/-
Definitions of parallel composition and involution in Ruby HDL. Parallel composition combines two relations side-by-side. Involution swaps the domain and codomain.
-/
def ruby_par {α β γ δ : Type} (R : Ruby α β) (S : Ruby γ δ) : Ruby (α × γ) (β × δ) :=
  fun (a, c) (b, d) => R a b ∧ S c d

def ruby_inv {α β : Type} (R : Ruby α β) : Ruby β α :=
  fun b a => R a b

/-
Definition of the `mm` circuit (max ; min) using the inverse of min to match types and semantics. Specification: (a, b) is related to (x, y) by `mm` iff max(a, b) = min(x, y).
-/
def ruby_mm : Ruby (Nat × Nat) (Nat × Nat) := ruby_seq ruby_max (ruby_inv ruby_min)

theorem ruby_mm_spec (a b x y : Nat) :
  ruby_mm (a, b) (x, y) ↔ (if a ≥ b then a else b) = (if x < y then x else y) := by
    constructor;
    · rintro ⟨ p, hp₁, hp₂ ⟩;
      unfold ruby_max ruby_inv ruby_min at *;
      grind;
    · intro h;
      unfold ruby_mm;
      split_ifs at h <;> simp_all +decide [ ruby_seq, ruby_max, ruby_inv, ruby_min ];
      · exact ⟨ x, Or.inr ⟨ by linarith, rfl ⟩, Or.inl rfl ⟩;
      · exact ⟨ y, Or.inr ⟨ by linarith, rfl ⟩, Or.inr rfl ⟩

/-
Wiring primitives: swap, associativity, and applying a relation to the first or second component of a pair.
-/
def ruby_swap {α β : Type} : Ruby (α × β) (β × α) := fun (a, b) (c, d) => c = b ∧ d = a

def ruby_assoc_l {α β γ : Type} : Ruby (α × (β × γ)) ((α × β) × γ) := fun (a, (b, c)) ((d, e), f) => d = a ∧ e = b ∧ f = c

def ruby_assoc_r {α β γ : Type} : Ruby ((α × β) × γ) (α × (β × γ)) := fun ((a, b), c) (d, (e, f)) => d = a ∧ e = b ∧ f = c

def ruby_fst {α β γ : Type} (R : Ruby α β) : Ruby (α × γ) (β × γ) := ruby_par R ruby_id

def ruby_snd {α β γ : Type} (R : Ruby β γ) : Ruby (α × β) (α × γ) := ruby_par ruby_id R

/-
Definitions for sequential circuits: RubyStream (signals over time), lifting combinational relations to streams, and the unit delay element with an initial value.
-/
def RubyStream (α : Type) := Nat → α

def ruby_lift {α β : Type} (R : Ruby α β) : Ruby (RubyStream α) (RubyStream β) :=
  fun s1 s2 => ∀ t, R (s1 t) (s2 t)

def ruby_delay {α : Type} (init : α) : Ruby (RubyStream α) (RubyStream α) :=
  fun s1 s2 => s2 0 = init ∧ ∀ t, s2 (t + 1) = s1 t

/-
Definition of a 2-element sorter using fork, min, and max. Specification: it outputs the min and max of the inputs.
-/
def ruby_sort2 : Ruby (Nat × Nat) (Nat × Nat) :=
  ruby_seq ruby_fork (ruby_par ruby_min ruby_max)

theorem ruby_sort2_spec (a b c d : Nat) :
  ruby_sort2 (a, b) (c, d) ↔ c = min a b ∧ d = max a b := by
    unfold ruby_sort2;
    unfold ruby_seq ruby_par ruby_fork ruby_min ruby_max;
    cases le_total a b <;> simp +decide [ *, min_eq_left, max_eq_right ];
    · grind;
    · grind

/-
Definition of feedback (looping) combinator. It connects the second output of R to the second input of R via a delay/relation D.
-/
def ruby_feedback {α β σ : Type} (R : Ruby (α × σ) (β × σ)) (D : Ruby σ σ) : Ruby α β :=
  fun a b => ∃ s s', R (a, s) (b, s') ∧ D s' s

/-
Definition of `ruby_lift2` to lift relations on pairs to streams of pairs. Definition of `ruby_sort_cell` using `ruby_lift2`. Specification of `ruby_sort_cell`.
-/
def ruby_lift2 {α β γ δ : Type} (R : Ruby (α × β) (γ × δ)) : Ruby (RubyStream α × RubyStream β) (RubyStream γ × RubyStream δ) :=
  fun (sa, sb) (sc, sd) => ∀ t, R (sa t, sb t) (sc t, sd t)

def ruby_sort_cell (init : Nat) : Ruby (RubyStream Nat) (RubyStream Nat) :=
  ruby_feedback (ruby_lift2 ruby_sort2) (ruby_delay init)

theorem ruby_sort_cell_spec (init : Nat) (x : RubyStream Nat) (y : RubyStream Nat) :
  ruby_sort_cell init x y ↔
  ∃ s : RubyStream Nat,
    s 0 = init ∧
    ∀ t, y t = min (x t) (s t) ∧ s (t + 1) = max (x t) (s t) := by
      constructor;
      · -- By definition of ruby_sort_cell, if ruby_sort_cell init x y, then there exists a stream s such that ruby_inner_sort x s (y, s).
        intro h
        obtain ⟨s, hs⟩ := h;
        obtain ⟨ s', hs₁, hs₂ ⟩ := hs;
        unfold ruby_lift2 at hs₁;
        unfold ruby_delay at hs₂;
        use s;
        simp_all +decide [ ruby_sort2_spec ];
      · unfold ruby_sort_cell;
        unfold ruby_lift2 ruby_delay;
        rintro ⟨ s, hs₀, hs ⟩;
        use s;
        use fun t => s ( t + 1 );
        simp_all +decide [ ruby_sort2_spec ]

/-
Definition of a 2-cell priority queue. Simulation theorem: given inputs 30, 5, 25 and initial values 10, 20, the outputs at t=0, 1, 2 are 10, 5, 20 respectively.
-/
def ruby_pqueue_2 (init1 init2 : Nat) : Ruby (RubyStream Nat) (RubyStream Nat) :=
  ruby_seq (ruby_sort_cell init1) (ruby_sort_cell init2)

theorem ruby_pqueue_2_sim (x y : RubyStream Nat) :
  (x 0 = 30 ∧ x 1 = 5 ∧ x 2 = 25) →
  ruby_pqueue_2 10 20 x y →
  y 0 = 10 ∧ y 1 = 5 ∧ y 2 = 20 := by
    rintro ⟨ h₀, h₁, h₂ ⟩ ⟨ s, hs₁, hs₂ ⟩;
    obtain ⟨ s₁, hs₁ ⟩ := ruby_sort_cell_spec 10 x s |>.1 hs₁
    obtain ⟨ s₂, hs₂ ⟩ := ruby_sort_cell_spec 20 s y |>.1 hs₂;
    grind

/-
Associativity of series composition: (R ; S) ; T = R ; (S ; T).
-/
theorem ruby_seq_assoc {α β γ δ : Type} (R : Ruby α β) (S : Ruby β γ) (T : Ruby γ δ) :
  ruby_seq (ruby_seq R S) T = ruby_seq R (ruby_seq S T) := by
    funext a b;
    simp [ ruby_seq ];
    grind

/-
Algebraic law: The inverse of a series composition is the reverse series composition of the inverses. (R ; S)† = S† ; R†.
-/
theorem ruby_inv_seq {α β γ : Type} (R : Ruby α β) (S : Ruby β γ) :
  ruby_inv (ruby_seq R S) = ruby_seq (ruby_inv S) (ruby_inv R) := by
    -- By definition of ruby_inv and ruby_seq, we can rewrite the goal using the definitions and show that the two relations are equal.
    apply funext; intro c; apply funext; intro a; simp [ruby_inv, ruby_seq];
    grind

/-
Deep embedding of Ruby: `HwType` for hardware types, `interpType` mapping to Lean types, and `RubyTerm` for the syntax of Ruby circuits.
-/
inductive HwType
| Bit
| Nat
| Pair (a b : HwType)
| Stream (a : HwType)

def interpType : HwType → Type
| HwType.Bit => Bool
| HwType.Nat => Nat
| HwType.Pair a b => interpType a × interpType b
| HwType.Stream a => RubyStream (interpType a)

inductive RubyTerm : HwType → HwType → Type
| Id {a} : RubyTerm a a
| Seq {a b c} (R : RubyTerm a b) (S : RubyTerm b c) : RubyTerm a c
| Par {a b c d} (R : RubyTerm a b) (S : RubyTerm c d) : RubyTerm (HwType.Pair a c) (HwType.Pair b d)
| Inv {a b} (R : RubyTerm a b) : RubyTerm b a
| Fork {a} : RubyTerm a (HwType.Pair a a)
| Mux {a} : RubyTerm (HwType.Pair HwType.Bit (HwType.Pair a a)) a
| Max : RubyTerm (HwType.Pair HwType.Nat HwType.Nat) HwType.Nat
| Min : RubyTerm (HwType.Pair HwType.Nat HwType.Nat) HwType.Nat
| Delay {a} (init : interpType a) : RubyTerm (HwType.Stream a) (HwType.Stream a)
| Lift2 {a b c d} (R : RubyTerm (HwType.Pair a b) (HwType.Pair c d)) : RubyTerm (HwType.Pair (HwType.Stream a) (HwType.Stream b)) (HwType.Pair (HwType.Stream c) (HwType.Stream d))
| Feedback {a b s} (R : RubyTerm (HwType.Pair a s) (HwType.Pair b s)) (D : RubyTerm s s) : RubyTerm a b

/-
Interpretation function mapping Ruby terms (deep embedding) to Ruby relations (shallow embedding).
-/
def interpRuby {a b : HwType} : RubyTerm a b → Ruby (interpType a) (interpType b)
| RubyTerm.Id => ruby_id
| RubyTerm.Seq R S => ruby_seq (interpRuby R) (interpRuby S)
| RubyTerm.Par R S => ruby_par (interpRuby R) (interpRuby S)
| RubyTerm.Inv R => ruby_inv (interpRuby R)
| RubyTerm.Fork => ruby_fork
| RubyTerm.Mux => ruby_mux
| RubyTerm.Max => ruby_max
| RubyTerm.Min => ruby_min
| RubyTerm.Delay init => ruby_delay init
| RubyTerm.Lift2 R => ruby_lift2 (interpRuby R)
| RubyTerm.Feedback R D => ruby_feedback (interpRuby R) (interpRuby D)

/-
Simple compiler from RubyTerm to Netlist (implemented for Id, Max, Min). Theorem: compiling Id with non-empty inputs adds blocks to the netlist.
-/
structure NetlistBlock where
  name : String
  inputs : List Nat
  outputs : List Nat
  deriving Repr, DecidableEq

structure Netlist where
  blocks : List NetlistBlock
  wireCount : Nat
  deriving Repr

def emptyNetlist : Netlist := { blocks := [], wireCount := 0 }

def addBlock (b : NetlistBlock) (nl : Netlist) : Netlist :=
  { nl with blocks := b :: nl.blocks }

def compile {a b : HwType} (t : RubyTerm a b) (ins : List Nat) (outs : List Nat) (nl : Netlist) : Netlist :=
  match t with
  | RubyTerm.Id =>
    List.zip ins outs |>.foldl (fun nl (i, o) => addBlock { name := "Assign", inputs := [i], outputs := [o] } nl) nl
  | RubyTerm.Max =>
    addBlock { name := "Max", inputs := ins, outputs := outs } nl
  | RubyTerm.Min =>
    addBlock { name := "Min", inputs := ins, outputs := outs } nl
  | _ => nl

theorem compile_id_nonempty (ins outs : List Nat) (nl : Netlist) :
  ins.length > 0 → ins.length = outs.length →
  (compile (RubyTerm.Id (a := HwType.Bit)) ins outs nl).blocks.length > nl.blocks.length := by
    cases ins <;> cases outs <;> norm_num [ List.range' ] at *;
    rename_i k l;
    induction l generalizing k <;> simp_all +decide [ List.range' ];
    · exact?;
    · rename_i k' l' ih;
      rename_i l'';
      intro h;
      unfold compile; simp +decide [ h ] ;
      induction' l''.zip ( k' :: l' ) using List.reverseRecOn with x xs ih <;> simp_all +decide [ List.foldl ];
      · exact Nat.lt_succ_self _;
      · exact lt_of_lt_of_le ih ( by simp +decide [ addBlock ] )

/-
Algebraic law: The inverse of a parallel composition is the parallel composition of the inverses. (R || S)† = R† || S†.
-/
theorem ruby_inv_par {α β γ δ : Type} (R : Ruby α β) (S : Ruby γ δ) :
  ruby_inv (ruby_par R S) = ruby_par (ruby_inv R) (ruby_inv S) := by
    -- By definition of ruby_inv and ruby_par, we can rewrite both sides of the equation.
    funext; simp [ruby_inv, ruby_par]

/-
Algebraic law: Identity element for series composition. id ; R = R.
-/
theorem ruby_id_seq {α β : Type} (R : Ruby α β) :
  ruby_seq ruby_id R = R := by
    -- By definition of `ruby_seq`, we have that `ruby_seq ruby_id R a b` is equivalent to `∃ b, ruby_id a b ∧ R b b`.
    funext a b; simp [ruby_seq, ruby_id]

/-
Algebraic law: Involution is its own inverse. (R†)† = R.
-/
theorem ruby_inv_inv {α β : Type} (R : Ruby α β) :
  ruby_inv (ruby_inv R) = R := by
    exact?

/-
Algebraic law: The inverse of identity is identity. id† = id.
-/
theorem ruby_inv_id {α : Type} :
  ruby_inv (ruby_id : Ruby α α) = ruby_id := by
    funext a b; simp [ruby_inv, ruby_id];
    exact eq_comm

/-
Algebraic law: Distributivity of parallel composition over series composition. (R || S) ; (T || U) = (R ; T) || (S ; U).
-/
theorem ruby_par_distrib {α β γ δ ε ζ : Type}
  (R : Ruby α β) (S : Ruby γ δ) (T : Ruby β ε) (U : Ruby δ ζ) :
  ruby_seq (ruby_par R S) (ruby_par T U) = ruby_par (ruby_seq R T) (ruby_seq S U) := by
    funext a b;
    unfold ruby_seq ruby_par at *; aesop;

/-
Algebraic law: Right identity for series composition. R ; id = R.
-/
theorem ruby_seq_id_right {α β : Type} (R : Ruby α β) :
  ruby_seq R ruby_id = R := by
    -- By definition of series composition, we have:
    funext a c; simp [ruby_seq, ruby_id]

/-
Definition of the `mm` circuit term in the deep embedding.
-/
def term_mm : RubyTerm (HwType.Pair HwType.Nat HwType.Nat) (HwType.Pair HwType.Nat HwType.Nat) :=
  RubyTerm.Seq RubyTerm.Max (RubyTerm.Inv RubyTerm.Min)

/-
Improved compiler that handles `Seq`, `Par`, `Inv` and calculates wire widths.
Theorem: Compiling `term_mm` (Max ; Min†) results in exactly 2 blocks added to the netlist.
-/
def width : HwType → Nat
| HwType.Bit => 1
| HwType.Nat => 1
| HwType.Pair a b => width a + width b
| HwType.Stream a => width a

def compile_term {a b : HwType} (t : RubyTerm a b) (ins : List Nat) (outs : List Nat) (nl : Netlist) : Netlist :=
  match t with
  | RubyTerm.Id =>
    List.zip ins outs |>.foldl (fun nl (i, o) => addBlock { name := "Assign", inputs := [i], outputs := [o] } nl) nl
  | RubyTerm.Max =>
    addBlock { name := "Max", inputs := ins, outputs := outs } nl
  | RubyTerm.Min =>
    addBlock { name := "Min", inputs := ins, outputs := outs } nl
  | RubyTerm.Inv R =>
    compile_term R outs ins nl
  | RubyTerm.Seq (b := mid) R S =>
    let w := width mid
    let start := nl.wireCount
    let mids := List.range w |>.map (fun i => start + i)
    let nl' := { nl with wireCount := nl.wireCount + w }
    let nl'' := compile_term R ins mids nl'
    compile_term S mids outs nl''
  | RubyTerm.Par (a := a) (b := b) R S =>
    let (ins1, ins2) := (ins.take (width a), ins.drop (width a))
    let (outs1, outs2) := (outs.take (width b), outs.drop (width b))
    let nl' := compile_term R ins1 outs1 nl
    compile_term S ins2 outs2 nl'
  | _ => nl

theorem compile_term_mm_correct (nl : Netlist) :
  let ins := [0, 1]
  let outs := [2, 3]
  let res := compile_term term_mm ins outs nl
  res.blocks.length = nl.blocks.length + 2 := by
    exact?

/-
Verification of the 2-element sorter circuit. It correctly outputs the minimum and maximum of its inputs.
-/
theorem ruby_sort2_spec_proven (a b c d : Nat) :
  ruby_sort2 (a, b) (c, d) ↔ c = min a b ∧ d = max a b := by
    exact?

/-
Deep embedding of the 2-element sorter and proof that it interprets to the shallow embedding.
-/
def term_sort2 : RubyTerm (HwType.Pair HwType.Nat HwType.Nat) (HwType.Pair HwType.Nat HwType.Nat) :=
  RubyTerm.Seq RubyTerm.Fork (RubyTerm.Par RubyTerm.Min RubyTerm.Max)

theorem term_sort2_correct : interpRuby term_sort2 = ruby_sort2 := by
  rfl

/-
Verification of the `mm` (max; min) circuit. It relates inputs (a, b) to outputs (x, y) iff max(a, b) = min(x, y).
-/
theorem ruby_mm_spec_proven (a b x y : Nat) :
  ruby_mm (a, b) (x, y) ↔ (if a ≥ b then a else b) = (if x < y then x else y) := by
    exact?

/-
Algebraic law: The inverse of a series composition is the reverse series composition of the inverses. (R ; S)† = S† ; R†.
-/
theorem ruby_inv_seq_proven {α β γ : Type} (R : Ruby α β) (S : Ruby β γ) :
  ruby_inv (ruby_seq R S) = ruby_seq (ruby_inv S) (ruby_inv R) := by
    exact?

/-
Verification of the sort cell. It maintains an internal state `s` initialized to `init`. At each step `t`, it outputs the minimum of input `x` and state `s`, and updates the state to the maximum.
-/
theorem ruby_sort_cell_spec_proven (init : Nat) (x : RubyStream Nat) (y : RubyStream Nat) :
  ruby_sort_cell init x y ↔
  ∃ s : RubyStream Nat,
    s 0 = init ∧
    ∀ t, y t = min (x t) (s t) ∧ s (t + 1) = max (x t) (s t) := by
      exact?

/-
Simulation of the 2-cell priority queue with inputs 30, 5, 25 and initial values 10, 20. The output should be 10, 5, 20.
-/
theorem ruby_pqueue_2_sim_proven (x y : RubyStream Nat) :
  (x 0 = 30 ∧ x 1 = 5 ∧ x 2 = 25) →
  ruby_pqueue_2 10 20 x y →
  y 0 = 10 ∧ y 1 = 5 ∧ y 2 = 20 := by
    exact?

/-
Associativity of series composition: (R ; S) ; T = R ; (S ; T).
-/
theorem ruby_seq_assoc_proven {α β γ δ : Type} (R : Ruby α β) (S : Ruby β γ) (T : Ruby γ δ) :
  ruby_seq (ruby_seq R S) T = ruby_seq R (ruby_seq S T) := by
    -- By definition of ruby_seq, we can rewrite the left-hand side and right-hand side using the existence of intermediate values.
    apply ruby_seq_assoc

/-
Definitions for symbolic expressions (`RubyExpr`), their evaluation (`evalExpr`), and the type interpretation for symbolic simulation (`interpExpr`).
-/
inductive RubyExpr
| Var (name : String)
| Lit (n : Nat)
| Add (e1 e2 : RubyExpr)
| Min (e1 e2 : RubyExpr)
| Max (e1 e2 : RubyExpr)
deriving Repr, DecidableEq

def evalExpr (env : String → Nat) : RubyExpr → Nat
| RubyExpr.Var s => env s
| RubyExpr.Lit n => n
| RubyExpr.Add e1 e2 => evalExpr env e1 + evalExpr env e2
| RubyExpr.Min e1 e2 => min (evalExpr env e1) (evalExpr env e2)
| RubyExpr.Max e1 e2 => max (evalExpr env e1) (evalExpr env e2)

def interpExpr : HwType → Type
| HwType.Bit => Bool
| HwType.Nat => RubyExpr
| HwType.Pair a b => interpExpr a × interpExpr b
| HwType.Stream a => Nat → interpExpr a

/-
Helper functions for symbolic interpretation:
`constExpr`: Lifts a concrete value to a symbolic expression.
`simulateFeedback`: Simulates a feedback loop given a step function, initial state, and input stream.
-/
def constExpr : (a : HwType) → interpType a → interpExpr a
| HwType.Bit, b => b
| HwType.Nat, n => RubyExpr.Lit n
| HwType.Pair a b, (x, y) => (constExpr a x, constExpr b y)
| HwType.Stream a, s => fun t => constExpr a (s t)

def simulateFeedback {A B S : Type} (step : A × S → B × S) (init : S) (input : Nat → A) : Nat → B :=
  let rec state : Nat → S
  | 0 => init
  | n + 1 => (step (input n, state n)).2
  fun t => (step (input t, state t)).1

/-
Helper function `defaultExpr` to provide a default value for `interpExpr a`. Used for unsupported cases in symbolic interpretation.
-/
def defaultExpr (a : HwType) : interpExpr a :=
  match a with
  | HwType.Bit => false
  | HwType.Nat => RubyExpr.Lit 0
  | HwType.Pair a b => (defaultExpr a, defaultExpr b)
  | HwType.Stream a => fun _ => defaultExpr a

/-
Helper structure and function `extractFeedback` to safely extract components from a feedback loop involving `Lift2` and `Delay`.
It returns the inner relation `R'`, the initial value `init`, and equality proofs for the types if the pattern matches.
-/
structure FeedbackComponents (a b s : HwType) where
  a' : HwType
  b' : HwType
  s' : HwType
  R' : RubyTerm (a'.Pair s') (b'.Pair s')
  init : interpType s'
  h_a : a = HwType.Stream a'
  h_b : b = HwType.Stream b'
  h_s : s = HwType.Stream s'

def extractFeedback {a b s : HwType} (R : RubyTerm (a.Pair s) (b.Pair s)) (D : RubyTerm s s) : Option (FeedbackComponents a b s) :=
  match a, b, s, R, D with
  | HwType.Stream a', HwType.Stream b', HwType.Stream s', RubyTerm.Lift2 R', RubyTerm.Delay init =>
    some { a' := a', b' := b', s' := s', R' := R', init := init, h_a := rfl, h_b := rfl, h_s := rfl }
  | _, _, _, _, _ => none

/-
Lemma stating that the relation extracted by `extractFeedback` is strictly smaller in size than the input relation `R`.
This is crucial for proving termination of `symbolicInterp`.
Retrying due to previous internal error.
-/
theorem extractFeedback_decreases {a b s : HwType} (R : RubyTerm (a.Pair s) (b.Pair s)) (D : RubyTerm s s) (c : FeedbackComponents a b s) :
  extractFeedback R D = some c → sizeOf c.R' < sizeOf R := by
    cases c;
    cases R;
    all_goals cases D;
    all_goals unfold extractFeedback; aesop;

/-
Symbolic interpretation function `symbolicInterp`.
It maps a `RubyTerm` and symbolic inputs to symbolic outputs.
It handles combinational logic, delays, and feedback loops (restricted to `Lift2` and `Delay` for termination).
Uses `simulateFeedback` to handle the feedback loop.
Uses `extractFeedback` to safely extract components from the feedback loop.
Uses `congrArg` for casts to avoid extra proof obligations.
Uses `sizeOf t` for termination, with a robust `decreasing_by` block that attempts to solve all goals without sorries.
-/
def symbolicInterp {a b : HwType} (t : RubyTerm a b) (inp : interpExpr a) : interpExpr b :=
  match t with
  | RubyTerm.Id => inp
  | RubyTerm.Seq R S => symbolicInterp S (symbolicInterp R inp)
  | RubyTerm.Par R S => (symbolicInterp R inp.1, symbolicInterp S inp.2)
  | RubyTerm.Inv R => defaultExpr _
  | RubyTerm.Fork => (inp, inp)
  | RubyTerm.Mux => cond inp.1 inp.2.1 inp.2.2
  | RubyTerm.Max => RubyExpr.Max inp.1 inp.2
  | RubyTerm.Min => RubyExpr.Min inp.1 inp.2
  | RubyTerm.Delay (a := a) init => fun t => match t with
      | 0 => constExpr a init
      | n+1 => inp n
  | RubyTerm.Lift2 R =>
      let (sa, sb) := inp
      let res (t : Nat) := symbolicInterp R (sa t, sb t)
      (fun t => (res t).1, fun t => (res t).2)
  | RubyTerm.Feedback (a := a) (b := b) (s := s) R D =>
      match h : extractFeedback R D with
      | some c =>
        let inp_stream : Nat → interpExpr c.a' :=
          cast (congrArg interpExpr c.h_a) inp
        let step (pair : interpExpr c.a' × interpExpr c.s') : interpExpr c.b' × interpExpr c.s' :=
          symbolicInterp c.R' pair
        let res_stream : Nat → interpExpr c.b' :=
          simulateFeedback step (constExpr c.s' c.init) inp_stream
        cast (congrArg interpExpr c.h_b.symm) res_stream
      | none => defaultExpr _
  termination_by sizeOf t
  decreasing_by
    all_goals simp_wf
    all_goals try simp [sizeOf]
    all_goals try (have := extractFeedback_decreases _ _ _ h; simp [sizeOf] at this; linarith)
    all_goals linarith

/-
Verification of symbolic simulation for `sort2`.
Symbolic simulation of `term_sort2` yields expressions that evaluate to the correct sorted values according to `ruby_sort2`.
-/
theorem symbolic_sort2_correct (env : String → Nat) (ea eb : RubyExpr) :
  let (ex, ey) := symbolicInterp term_sort2 (ea, eb)
  let va := evalExpr env ea
  let vb := evalExpr env eb
  let vx := evalExpr env ex
  let vy := evalExpr env ey
  ruby_sort2 (va, vb) (vx, vy) := by
    unfold term_sort2;
    unfold symbolicInterp;
    unfold symbolicInterp; simp +decide [ ruby_sort2_spec ] ;
    unfold symbolicInterp;
    unfold symbolicInterp; aesop;

/-
Deep embedding of the priority queue circuit and proof that it interprets to the shallow embedding.
-/
def term_sort_cell (init : Nat) : RubyTerm (HwType.Stream HwType.Nat) (HwType.Stream HwType.Nat) :=
  RubyTerm.Feedback (RubyTerm.Lift2 term_sort2) (RubyTerm.Delay init)

def term_pqueue_2 (init1 init2 : Nat) : RubyTerm (HwType.Stream HwType.Nat) (HwType.Stream HwType.Nat) :=
  RubyTerm.Seq (term_sort_cell init1) (term_sort_cell init2)

theorem term_pqueue_2_correct (init1 init2 : Nat) :
  interpRuby (term_pqueue_2 init1 init2) = ruby_pqueue_2 init1 init2 := by
    exact?

/-
Extended compiler `compile_ruby` that handles all Ruby constructs including `Fork`, `Mux`, `Lift2`, `Delay`, and `Feedback`.
It generates a netlist by recursively traversing the term.
For `Feedback`, it allocates new wires for the state and compiles the inner relation and the delay element.
-/
def width_extended : HwType → Nat
| HwType.Bit => 1
| HwType.Nat => 1
| HwType.Pair a b => width_extended a + width_extended b
| HwType.Stream a => width_extended a

def compile_ruby {a b : HwType} (t : RubyTerm a b) (ins : List Nat) (outs : List Nat) (nl : Netlist) : Netlist :=
  match t with
  | RubyTerm.Id =>
    List.zip ins outs |>.foldl (fun nl (i, o) => addBlock { name := "Assign", inputs := [i], outputs := [o] } nl) nl
  | RubyTerm.Max =>
    addBlock { name := "Max", inputs := ins, outputs := outs } nl
  | RubyTerm.Min =>
    addBlock { name := "Min", inputs := ins, outputs := outs } nl
  | RubyTerm.Fork =>
    -- ins has length w, outs has length 2w.
    -- We assume outs is [o1_1, ..., o1_w, o2_1, ..., o2_w]
    let w := ins.length
    let outs1 := outs.take w
    let outs2 := outs.drop w
    let nl' := List.zip ins outs1 |>.foldl (fun nl (i, o) => addBlock { name := "Assign", inputs := [i], outputs := [o] } nl) nl
    List.zip ins outs2 |>.foldl (fun nl (i, o) => addBlock { name := "Assign", inputs := [i], outputs := [o] } nl) nl'
  | RubyTerm.Mux =>
    -- ins: [c, x1...xw, y1...yw], outs: [z1...zw]
    addBlock { name := "Mux", inputs := ins, outputs := outs } nl
  | RubyTerm.Inv R =>
    compile_ruby R outs ins nl
  | RubyTerm.Seq (b := mid) R S =>
    let w := width_extended mid
    let start := nl.wireCount
    let mids := List.range w |>.map (fun i => start + i)
    let nl' := { nl with wireCount := nl.wireCount + w }
    let nl'' := compile_ruby R ins mids nl'
    compile_ruby S mids outs nl''
  | RubyTerm.Par (a := a) (b := b) R S =>
    let (ins1, ins2) := (ins.take (width_extended a), ins.drop (width_extended a))
    let (outs1, outs2) := (outs.take (width_extended b), outs.drop (width_extended b))
    let nl' := compile_ruby R ins1 outs1 nl
    compile_ruby S ins2 outs2 nl'
  | RubyTerm.Lift2 R =>
    compile_ruby R ins outs nl
  | RubyTerm.Delay init =>
    addBlock { name := "DFF", inputs := ins, outputs := outs } nl
  | RubyTerm.Feedback (s := s) R D =>
    let w_s := width_extended s
    let start := nl.wireCount
    let s_wires := List.range w_s |>.map (fun i => start + i)
    let s_prime_wires := List.range w_s |>.map (fun i => start + w_s + i)
    let nl' := { nl with wireCount := nl.wireCount + 2 * w_s }
    -- R : (a, s) -> (b, s)
    -- inputs to R: ins ++ s_wires
    -- outputs from R: outs ++ s_prime_wires
    let nl'' := compile_ruby R (ins ++ s_wires) (outs ++ s_prime_wires) nl'
    -- D : s -> s (actually s' -> s in feedback loop)
    -- D connects s' to s.
    compile_ruby D s_prime_wires s_wires nl''

/-
Compilation of the 2-cell priority queue to a netlist.
Theorem: The resulting netlist is not empty.
-/
def compiled_pqueue_2 : Netlist :=
  let t := term_pqueue_2 10 20
  let ins := [0] -- One input stream
  let outs := [1] -- One output stream
  compile_ruby t ins outs emptyNetlist

theorem compiled_pqueue_2_nonempty : compiled_pqueue_2.blocks.length > 0 := by
  decide +revert

/-
Test of symbolic simulation for the priority queue.
Verifies that simulating `term_pqueue_2` with symbolic literals yields the correct concrete values after evaluation.
-/
def emptyEnv : String → Nat := fun _ => 0

theorem test_pqueue_symbolic :
  let x_stream (t : Nat) : RubyExpr :=
    match t with
    | 0 => RubyExpr.Lit 30
    | 1 => RubyExpr.Lit 5
    | 2 => RubyExpr.Lit 25
    | _ => RubyExpr.Lit 0
  let y_stream := symbolicInterp (term_pqueue_2 10 20) x_stream
  evalExpr emptyEnv (y_stream 0) = 10 ∧
  evalExpr emptyEnv (y_stream 1) = 5 ∧
  evalExpr emptyEnv (y_stream 2) = 20 := by
    unfold symbolicInterp term_pqueue_2 term_sort_cell term_sort2;
    unfold symbolicInterp; simp +decide [ extractFeedback ] ;
    unfold symbolicInterp; simp +decide [ * ] ;
    unfold symbolicInterp; simp +decide [ * ] ;
    unfold symbolicInterp; simp +decide [ * ] ;
    unfold symbolicInterp; simp +decide [ * ] ;

/-
Symbolic interpretation function `symbolicInterpFuel` with a fuel parameter to ensure termination.
This avoids the complex termination proof for the feedback loop.
It behaves exactly like `symbolicInterp` as long as the fuel is sufficient (greater than the depth of the circuit).
Since the circuit is finite, a sufficiently large fuel will work.
-/
def symbolicInterpFuel {a b : HwType} (fuel : Nat) (t : RubyTerm a b) (inp : interpExpr a) : interpExpr b :=
  match fuel with
  | 0 => defaultExpr b
  | fuel' + 1 =>
    match t with
    | RubyTerm.Id => inp
    | RubyTerm.Seq R S => symbolicInterpFuel fuel' S (symbolicInterpFuel fuel' R inp)
    | RubyTerm.Par R S => (symbolicInterpFuel fuel' R inp.1, symbolicInterpFuel fuel' S inp.2)
    | RubyTerm.Inv R => defaultExpr _
    | RubyTerm.Fork => (inp, inp)
    | RubyTerm.Mux => cond inp.1 inp.2.1 inp.2.2
    | RubyTerm.Max => RubyExpr.Max inp.1 inp.2
    | RubyTerm.Min => RubyExpr.Min inp.1 inp.2
    | RubyTerm.Delay (a := a) init => fun t => match t with
        | 0 => constExpr a init
        | n+1 => inp n
    | RubyTerm.Lift2 R =>
        let (sa, sb) := inp
        let res (t : Nat) := symbolicInterpFuel fuel' R (sa t, sb t)
        (fun t => (res t).1, fun t => (res t).2)
    | RubyTerm.Feedback (a := a) (b := b) (s := s) R D =>
        match h : extractFeedback R D with
        | some c =>
          let inp_stream : Nat → interpExpr c.a' :=
            cast (congrArg interpExpr c.h_a) inp
          let step (pair : interpExpr c.a' × interpExpr c.s') : interpExpr c.b' × interpExpr c.s' :=
            symbolicInterpFuel fuel' c.R' pair
          let res_stream : Nat → interpExpr c.b' :=
            simulateFeedback step (constExpr c.s' c.init) inp_stream
          cast (congrArg interpExpr c.h_b.symm) res_stream
        | none => defaultExpr _

/-
Algebraic law: The inverse of a parallel composition is the parallel composition of the inverses. (R || S)† = R† || S†.
-/
theorem ruby_inv_par_proven {α β γ δ : Type} (R : Ruby α β) (S : Ruby γ δ) :
  ruby_inv (ruby_par R S) = ruby_par (ruby_inv R) (ruby_inv S) := by
    exact?

/-
Algebraic law: Left identity for series composition. id ; R = R.
-/
theorem ruby_id_seq_proven {α β : Type} (R : Ruby α β) :
  ruby_seq ruby_id R = R := by
    exact?

/-
Test of symbolic simulation for the priority queue using `symbolicInterpFuel`.
Verifies that simulating `term_pqueue_2` with symbolic literals yields the correct concrete values after evaluation.
-/
theorem test_pqueue_symbolic_fuel :
  let x_stream (t : Nat) : RubyExpr :=
    match t with
    | 0 => RubyExpr.Lit 30
    | 1 => RubyExpr.Lit 5
    | 2 => RubyExpr.Lit 25
    | _ => RubyExpr.Lit 0
  let y_stream := symbolicInterpFuel 100 (term_pqueue_2 10 20) x_stream
  evalExpr emptyEnv (y_stream 0) = 10 ∧
  evalExpr emptyEnv (y_stream 1) = 5 ∧
  evalExpr emptyEnv (y_stream 2) = 20 := by
    unfold term_pqueue_2 at *;
    unfold term_sort_cell at *; simp +decide [ term_sort2 ] at *;
